<Window x:Class="ImageManager.FontSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:ImageManager.Services"
        Title="{DynamicResource FontSelect}"
        Width="520" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="{DynamicResource GlobalFontFamily}"
        FontWeight="{DynamicResource GlobalFontWeight}">

    <Grid>
    <Border x:Name="RootBorder" CornerRadius="8"
            Background="{Binding CardBackground, Source={x:Static svc:ThemeManager.Instance}}"
            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Width="16" Height="16" Margin="0,0,6,0"
                            Background="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}">
                        <Border.OpacityMask>
                            <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/font2.png"/>
                        </Border.OpacityMask>
                    </Border>
                    <TextBlock Text="{DynamicResource FontSelect}" FontSize="12" FontWeight="Medium"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Click="Close_Click" Width="36" Height="28"
                        HorizontalAlignment="Right"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Border Width="14" Height="14"
                            Background="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}">
                        <Border.OpacityMask>
                            <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/close.png"/>
                        </Border.OpacityMask>
                    </Border>
                </Button>
            </Grid>

            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}"/>

            <!-- 内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="16,12,16,0">
                <StackPanel>

                    <!-- 字体选择 -->
                    <TextBlock Text="字体" FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="选择字体" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>

                            <ComboBox x:Name="FontComboBox"
                                      ItemsSource="{Binding InstalledFonts}"
                                      SelectedItem="{Binding SelectedFontFamily}"
                                      FontSize="12" Height="32"
                                      Background="{Binding ButtonBg, Source={x:Static svc:ThemeManager.Instance}}"
                                      Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                                      Margin="0,0,0,10"/>

                            <TextBlock Text="字重" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding FontWeightLabel}" FontSize="11"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                                           VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="100" Maximum="900"
                                        Value="{Binding SelectedFontWeight}"
                                        TickFrequency="100" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding SelectedFontWeight}" FontSize="10"
                                           TextAlignment="Right"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,12"/>

                    <!-- 预览区域 -->
                    <TextBlock Text="预览" FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="16"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="PreviewLarge"
                                       FontSize="20" Margin="0,0,0,12"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>

                            <TextBlock x:Name="PreviewMedium"
                                       Text="Terminal Image Transfer Management Tool"
                                       FontSize="14" Margin="0,0,0,10"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>

                            <TextBlock x:Name="PreviewSmall"
                                       Text="AaBbCcDdEeFf 0123456789 拖入图片或 Ctrl+V 粘贴截图"
                                       FontSize="12" Margin="0,0,0,10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>

                            <TextBlock x:Name="PreviewChinese"
                                       Text="天地玄黄 宇宙洪荒 日月盈昃 辰宿列张"
                                       FontSize="16" Margin="0,0,0,6"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>

                            <TextBlock x:Name="PreviewKorean"
                                       Text="가나다라마바사아자차카타파하"
                                       FontSize="14"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Grid Grid.Row="2" Margin="16,10,16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="恢复默认" Click="ResetFont_Click"
                            Padding="14,6" FontSize="11" Cursor="Hand"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}"
                            Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                    <Button Content="应用" Click="ApplyFont_Click"
                            Padding="14,6" FontSize="11" Cursor="Hand" Margin="8,0,0,0"
                            Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                            Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>

    <!-- 缩放拖拽手柄 -->
    <Border x:Name="ResizeN"  Height="4" VerticalAlignment="Top"    HorizontalAlignment="Stretch" Cursor="SizeNS" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeS"  Height="4" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Cursor="SizeNS" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeW"  Width="4"  VerticalAlignment="Stretch" HorizontalAlignment="Left"   Cursor="SizeWE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeE"  Width="4"  VerticalAlignment="Stretch" HorizontalAlignment="Right"  Cursor="SizeWE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeNW" Width="8" Height="8" VerticalAlignment="Top"    HorizontalAlignment="Left"   Cursor="SizeNWSE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeNE" Width="8" Height="8" VerticalAlignment="Top"    HorizontalAlignment="Right"  Cursor="SizeNESW" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeSW" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Left"   Cursor="SizeNESW" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeSE" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Right"  Cursor="SizeNWSE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    </Grid>
</Window>
