<Window x:Class="ImageManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ImageManager.Converters"
        xmlns:svc="clr-namespace:ImageManager.Services"
        Title="图片管理助手"
        Width="580" Height="680"
        MinWidth="460" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei, Segoe UI"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="12" Background="{Binding CardBackground, Source={x:Static svc:ThemeManager.Instance}}"
            BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="Transparent">
                <TextBlock Text="图片管理助手" FontSize="13" FontWeight="Medium"
                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Click="Minimize_Click" Width="36" Height="28"
                            Background="Transparent" BorderThickness="0" FontSize="13"
                            Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Cursor="Hand">
                        <TextBlock Text="─" FontSize="10" Margin="0,-2,0,0"/>
                    </Button>
                    <Button Click="Close_Click" Width="36" Height="28"
                            Background="Transparent" BorderThickness="0" FontSize="13"
                            Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Cursor="Hand">
                        <TextBlock Text="✕" FontSize="11" Margin="0,-1,0,0"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}"/>

            <!-- 主内容 -->
            <Grid Grid.Row="1" Margin="20,16,20,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 拖放区 -->
                <Border Grid.Row="0" x:Name="DropZone"
                        CornerRadius="10"
                        BorderBrush="{Binding DropZoneBorder, Source={x:Static svc:ThemeManager.Instance}}"
                        BorderThickness="1.5"
                        Background="Transparent"
                        Margin="0,0,0,12"
                        Padding="0,20"
                        AllowDrop="True"
                        Drop="DropZone_Drop"
                        DragEnter="DropZone_DragEnter"
                        DragLeave="DropZone_DragLeave"
                        DragOver="DropZone_DragOver">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="+" FontSize="20" FontWeight="Light"
                                   Foreground="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}" HorizontalAlignment="Center"/>
                        <TextBlock Text="拖入图片或 Ctrl+V 粘贴截图"
                                   FontSize="12" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 工具栏 -->
                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Content="全选"
                                  IsChecked="{Binding IsAllSelected}"
                                  FontSize="12" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                        <TextBlock FontSize="11" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                   VerticalAlignment="Center" Margin="10,0,0,0">
                            <Run Text="{Binding TotalCount, Mode=OneWay}"/><Run Text=" 项"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}">
                            已选 <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Click="Settings_Click" Padding="4,2" Margin="8,0,0,0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="设置">
                            <TextBlock Text="⚙" FontSize="14" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 文件列表 -->
                <Border Grid.Row="2" CornerRadius="10"
                        Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                        BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                    <Grid>
                        <!-- 空状态 -->
                        <StackPanel VerticalAlignment="Center"
                                    Visibility="{Binding IsAny, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <TextBlock Text="&#x25A1;" FontSize="36" HorizontalAlignment="Center"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            <TextBlock Text="暂无图片" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                            <TextBlock Text="拖入图片或 Ctrl+V 粘贴截图" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- 图片列表 -->
                        <ListBox x:Name="ImageListBox"
                                 ItemsSource="{Binding ImageItems}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="4"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="8,7" Margin="2,1"
                                            Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"/>

                                            <Grid Grid.Column="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="44" Height="32"
                                                        CornerRadius="4"
                                                        Background="{Binding ButtonBg, Source={x:Static svc:ThemeManager.Instance}}"
                                                        ClipToBounds="True"
                                                        Margin="0,0,10,0">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding FilePath}"
                                                               FontSize="10"
                                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <ListBox.ContextMenu>
                                <ContextMenu FontSize="12">
                                    <MenuItem Header="复制图片"
                                              Command="{Binding DataContext.CopyImageToClipboardCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="复制路径"
                                              Command="{Binding DataContext.CopySelectedPathsCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <MenuItem Header="重命名"
                                              Command="{Binding DataContext.RenameItemCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="打开所在目录"
                                              Command="{Binding DataContext.OpenContainingFolderCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="删除"
                                              Command="{Binding DataContext.DeleteSelectedCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                              Foreground="{Binding DangerFg, Source={x:Static svc:ThemeManager.Instance}}"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 操作按钮 -->
                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Click="PasteToWindow_Click" Padding="14,7" Cursor="Hand"
                                Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}" Foreground="White"
                                FontSize="12" FontWeight="SemiBold" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2191;" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="粘贴到窗口"/>
                            </StackPanel>
                        </Button>

                        <Button Click="CopyPaths_Click" Padding="14,7" Cursor="Hand"
                                Background="{Binding ButtonBg, Source={x:Static svc:ThemeManager.Instance}}" Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                                FontSize="12" Margin="6,0,0,0" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{Binding ButtonHover, Source={x:Static svc:ThemeManager.Instance}}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{Binding ButtonPressed, Source={x:Static svc:ThemeManager.Instance}}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2398;" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="复制路径"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Click="DeleteSelected_Click" Padding="14,7" Cursor="Hand"
                                Background="Transparent" Foreground="{Binding DangerFg, Source={x:Static svc:ThemeManager.Instance}}"
                                FontSize="12" Margin="0,0,6,0" BorderThickness="1"
                                BorderBrush="{Binding DangerFg, Source={x:Static svc:ThemeManager.Instance}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{Binding DangerBg, Source={x:Static svc:ThemeManager.Instance}}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2715;" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="删除"/>
                            </StackPanel>
                        </Button>

                        <Button Click="ClearAll_Click" Padding="14,7" Cursor="Hand"
                                Background="Transparent" Foreground="{Binding DangerFg, Source={x:Static svc:ThemeManager.Instance}}"
                                FontSize="12" BorderThickness="1"
                                BorderBrush="{Binding DangerFg, Source={x:Static svc:ThemeManager.Instance}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{Binding DangerBg, Source={x:Static svc:ThemeManager.Instance}}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x21BA;" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="清空"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- 底栏 -->
            <Grid Grid.Row="2" Margin="20,0,20,10">
                <TextBlock FontSize="10" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           Text="{Binding SelectedFilePath, Mode=OneWay}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <CheckBox Content="删除时不询问"
                              IsChecked="{Binding DeleteWithoutConfirm}"
                              FontSize="10" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                    <CheckBox Content="退出清空"
                              IsChecked="{Binding AutoCleanOnExit}"
                              FontSize="10" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                              Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Height="1" VerticalAlignment="Top"
                    Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}"/>

            <!-- Toast -->
            <Canvas x:Name="ToastContainer"
                    Grid.RowSpan="3"
                    IsHitTestVisible="False"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,50"/>
        </Grid>
    </Border>
</Window>
