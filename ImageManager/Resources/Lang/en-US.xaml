<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Main Window -->
    <sys:String x:Key="AppTitle">Terminal Image Transfer Manager</sys:String>
    <sys:String x:Key="DropHint">Drop images here or Ctrl+V to paste screenshots</sys:String>
    <sys:String x:Key="SelectAll">Select All</sys:String>
    <sys:String x:Key="Items">items</sys:String>
    <sys:String x:Key="Selected">Selected</sys:String>
    <sys:String x:Key="EmptyState">No images</sys:String>
    <sys:String x:Key="PasteToWindow">Paste to Window</sys:String>
    <sys:String x:Key="CopyPath">Copy Path</sys:String>
    <sys:String x:Key="Delete">Delete</sys:String>
    <sys:String x:Key="ClearAll">Clear All</sys:String>
    <sys:String x:Key="DeleteNoAsk">Delete without confirmation</sys:String>
    <sys:String x:Key="CleanOnExit">Clean on exit</sys:String>

    <!-- Settings Window -->
    <sys:String x:Key="SettingsTitle">Settings</sys:String>
    <sys:String x:Key="Appearance">Appearance</sys:String>
    <sys:String x:Key="Personalization">Personalization</sys:String>
    <sys:String x:Key="ThemeMode">Theme</sys:String>
    <sys:String x:Key="Light">Light</sys:String>
    <sys:String x:Key="Dark">Dark</sys:String>
    <sys:String x:Key="FollowSystem">Follow System</sys:String>
    <sys:String x:Key="Transparency">Transparency</sys:String>
    <sys:String x:Key="Language">Language</sys:String>
    <sys:String x:Key="Storage">Storage</sys:String>
    <sys:String x:Key="TempFolder">Temp folder location</sys:String>
    <sys:String x:Key="SelectFolder">Select Folder</sys:String>
    <sys:String x:Key="RestoreDefault">Restore Default</sys:String>
    <sys:String x:Key="OpenFolder">Open Folder</sys:String>
    <sys:String x:Key="DeleteNoConfirm">Delete without confirmation</sys:String>
    <sys:String x:Key="AutoCleanOnExit">Auto clean temp files on exit</sys:String>
    <sys:String x:Key="PrivacyMode">Privacy Mode</sys:String>
    <sys:String x:Key="PrivacyModeDesc">Hides file paths and other sensitive info. Ideal for screen sharing or presentations.</sys:String>
    <sys:String x:Key="AlwaysOnTop">Always on Top</sys:String>
    <sys:String x:Key="AlwaysOnTopDesc">Window stays on top of other windows</sys:String>
    <sys:String x:Key="FontSelect">Font Settings</sys:String>
    <sys:String x:Key="FontWeightSelect">Font Weight</sys:String>
    <sys:String x:Key="FontSettingDesc">Customize app font and weight</sys:String>
    <sys:String x:Key="ResourcesSection">Resources</sys:String>
    <sys:String x:Key="DisableBlur">Disable frosted glass background to save resources</sys:String>
    <sys:String x:Key="BackgroundEffect">Background Effect</sys:String>
    <sys:String x:Key="BgGlass">Frosted Glass</sys:String>
    <sys:String x:Key="BgMica">Win11 Acrylic</sys:String>
    <sys:String x:Key="BgNone">None (Solid)</sys:String>
    <sys:String x:Key="BgHint">Frosted Glass blurs the desktop in real time; Win11 Acrylic uses the system material (requires Windows 10/11).</sys:String>
    <sys:String x:Key="Help">Help</sys:String>
    <sys:String x:Key="Tutorial">Tutorial</sys:String>
    <sys:String x:Key="Step1">1. Drop images into the window, or press Ctrl+V to paste screenshots</sys:String>
    <sys:String x:Key="Step2">2. Select the images you need, click "Copy Path" to copy to clipboard</sys:String>
    <sys:String x:Key="Step3">3. Press Ctrl+V in any AI terminal or window to paste the path</sys:String>
    <sys:String x:Key="Step4">4. Click "Paste to Window" to automatically paste the path to the foreground window</sys:String>
    <sys:String x:Key="Step5">5. Settings allow you to change background effect, font, language and privacy mode</sys:String>
    <sys:String x:Key="FAQ">FAQ</sys:String>
    <sys:String x:Key="Q1">Q: Paste to window not working?</sys:String>
    <sys:String x:Key="A1">A: After clicking, switch to the target window within 2 seconds. The tool will automatically send Ctrl+V.</sys:String>
    <sys:String x:Key="Q2">Q: What does Privacy Mode do?</sys:String>
    <sys:String x:Key="A2">A: When enabled, all file paths are masked as ********. Ideal for screen sharing or presentations.</sys:String>
    <sys:String x:Key="Q3">Q: Which background effect should I choose?</sys:String>
    <sys:String x:Key="A3">A: Frosted Glass suits most scenarios; Win11 Acrylic uses system material for a more transparent look; None gives a solid background.</sys:String>
    <sys:String x:Key="Q4">Q: How does the font setting work?</sys:String>
    <sys:String x:Key="A4">A: Click Font Settings in Appearance, select a font and weight, then click "Apply" to take effect globally.</sys:String>

