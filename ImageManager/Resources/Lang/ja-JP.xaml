<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- メインウィンドウ -->
    <sys:String x:Key="AppTitle">ターミナル画像転送管理ツール</sys:String>
    <sys:String x:Key="DropHint">画像をここにドラッグまたは Ctrl+V でスクリーンショットを貼り付け</sys:String>
    <sys:String x:Key="SelectAll">すべて選択</sys:String>
    <sys:String x:Key="Items">件</sys:String>
    <sys:String x:Key="Selected">選択中</sys:String>
    <sys:String x:Key="EmptyState">画像がありません</sys:String>
    <sys:String x:Key="PasteToWindow">ウィンドウに貼り付け</sys:String>
    <sys:String x:Key="CopyPath">パスをコピー</sys:String>
    <sys:String x:Key="Delete">削除</sys:String>
    <sys:String x:Key="ClearAll">すべてクリア</sys:String>
    <sys:String x:Key="DeleteNoAsk">削除時に確認しない</sys:String>
    <sys:String x:Key="CleanOnExit">終了時にクリーンアップ</sys:String>

    <!-- 設定ウィンドウ -->
    <sys:String x:Key="SettingsTitle">設定</sys:String>
    <sys:String x:Key="Personalization">パーソナライズ</sys:String>
    <sys:String x:Key="ThemeMode">テーマモード</sys:String>
    <sys:String x:Key="Light">ライト</sys:String>
    <sys:String x:Key="Dark">ダーク</sys:String>
    <sys:String x:Key="FollowSystem">システムに合わせる</sys:String>
    <sys:String x:Key="Transparency">透明度</sys:String>
    <sys:String x:Key="Language">言語</sys:String>
    <sys:String x:Key="Storage">ストレージ</sys:String>
    <sys:String x:Key="TempFolder">一時フォルダの場所</sys:String>
    <sys:String x:Key="SelectFolder">フォルダを選択</sys:String>
    <sys:String x:Key="RestoreDefault">デフォルトに戻す</sys:String>
    <sys:String x:Key="OpenFolder">フォルダを開く</sys:String>
    <sys:String x:Key="DeleteNoConfirm">削除時に確認しない</sys:String>
    <sys:String x:Key="AutoCleanOnExit">終了時に一時ファイルを自動削除</sys:String>
    <sys:String x:Key="ResourcesSection">リソース</sys:String>
    <sys:String x:Key="DisableBlur">リソース節約のためにフロストガラス背景を無効にする</sys:String>
    <sys:String x:Key="Help">ヘルプ</sys:String>
    <sys:String x:Key="Tutorial">使い方</sys:String>
    <sys:String x:Key="Step1">1. 画像をウィンドウにドラッグするか、Ctrl+V でスクリーンショットを貼り付けます</sys:String>
    <sys:String x:Key="Step2">2. 必要な画像を選択し、「パスをコピー」をクリックします</sys:String>
    <sys:String x:Key="Step3">3. AI ターミナルで Ctrl+V を押してパスを貼り付けます</sys:String>
    <sys:String x:Key="Step4">4.「ウィンドウに貼り付け」をクリックすると前台のウィンドウに自動で貼り付きます</sys:String>
    <sys:String x:Key="FAQ">よくある質問</sys:String>
    <sys:String x:Key="Q1">Q: ウィンドウへの貼り付けが反応しません</sys:String>
    <sys:String x:Key="A1">A: クリック後2秒以内にターゲットウィンドウに切り替えてください。ツールが自動で Ctrl+V を送信します。</sys:String>
    <sys:String x:Key="Q2">Q: 画像はどこに保存されますか？</sys:String>
    <sys:String x:Key="A2">A: デフォルトではシステムの一時ディレクトリに保存されます。ストレージ設定で場所を変更できます。</sys:String>
    <sys:String x:Key="Q3">Q: 閉じた後も画像は残りますか？</sys:String>
    <sys:String x:Key="A3">A:「終了時にクリーンアップ」を有効にすると、ウィンドウを閉じた時に一時ファイルが自動的に削除されます。</sys:String>
    <sys:String x:Key="About">バージョン情報</sys:String>
    <sys:String x:Key="AppName">アプリ名</sys:String>
    <sys:String x:Key="AppVersion">バージョン</sys:String>
    <sys:String x:Key="Framework">フレームワーク</sys:String>
    <sys:String x:Key="License">ライセンス</sys:String>
    <sys:String x:Key="OpenSourceDev">オープンソース開発者</sys:String>

</ResourceDictionary>
