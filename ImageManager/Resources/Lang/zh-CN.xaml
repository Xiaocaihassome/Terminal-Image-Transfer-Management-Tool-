                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- 主窗口 -->
    <sys:String x:Key="AppTitle">终端图片中转管理工具</sys:String>
    <sys:String x:Key="DropHint">拖入图片或 Ctrl+V 粘贴截图</sys:String>
    <sys:String x:Key="SelectAll">全选</sys:String>
    <sys:String x:Key="Items">项</sys:String>
    <sys:String x:Key="Selected">已选</sys:String>
    <sys:String x:Key="EmptyState">暂无图片</sys:String>
    <sys:String x:Key="PasteToWindow">粘贴到窗口</sys:String>
