<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- 主窗口 -->
    <sys:String x:Key="AppTitle">终端图片中转管理工具</sys:String>
    <sys:String x:Key="DropHint">拖入图片或 Ctrl+V 粘贴截图</sys:String>
    <sys:String x:Key="SelectAll">全选</sys:String>
    <sys:String x:Key="Items">项</sys:String>
    <sys:String x:Key="Selected">已选</sys:String>
    <sys:String x:Key="EmptyState">暂无图片</sys:String>
    <sys:String x:Key="PasteToWindow">粘贴到窗口</sys:String>
    <sys:String x:Key="CopyPath">复制路径</sys:String>
    <sys:String x:Key="Delete">删除</sys:String>
    <sys:String x:Key="ClearAll">清空</sys:String>
    <sys:String x:Key="DeleteNoAsk">删除时不询问</sys:String>
    <sys:String x:Key="CleanOnExit">退出清空</sys:String>

    <!-- 设置窗口 -->
    <sys:String x:Key="SettingsTitle">设置</sys:String>
    <sys:String x:Key="Appearance">外观</sys:String>
    <sys:String x:Key="Personalization">个性化</sys:String>
    <sys:String x:Key="ThemeMode">主题模式</sys:String>
    <sys:String x:Key="Light">浅色</sys:String>
    <sys:String x:Key="Dark">深色</sys:String>
    <sys:String x:Key="FollowSystem">跟随系统</sys:String>
    <sys:String x:Key="Transparency">透明度</sys:String>
    <sys:String x:Key="Language">语言</sys:String>
    <sys:String x:Key="Storage">存储</sys:String>
    <sys:String x:Key="TempFolder">临时文件夹位置</sys:String>
    <sys:String x:Key="SelectFolder">选择文件夹</sys:String>
    <sys:String x:Key="RestoreDefault">恢复默认</sys:String>
    <sys:String x:Key="OpenFolder">打开文件夹</sys:String>
    <sys:String x:Key="DeleteNoConfirm">删除时不再询问</sys:String>
    <sys:String x:Key="AutoCleanOnExit">退出时自动清空临时文件</sys:String>
    <sys:String x:Key="PrivacyMode">隐私模式</sys:String>
    <sys:String x:Key="PrivacyModeDesc">开启后隐藏文件路径等敏感信息，适用于屏幕共享或演示场景</sys:String>
    <sys:String x:Key="AlwaysOnTop">窗口置顶</sys:String>
    <sys:String x:Key="AlwaysOnTopDesc">开启后窗口始终显示在其他窗口上方</sys:String>
    <sys:String x:Key="FontSelect">字体设置</sys:String>
    <sys:String x:Key="FontWeightSelect">字重</sys:String>
    <sys:String x:Key="FontSettingDesc">自定义应用字体和字重</sys:String>
    <sys:String x:Key="ResourcesSection">资源</sys:String>
    <sys:String x:Key="DisableBlur">禁用毛玻璃背景以节省资源</sys:String>
    <sys:String x:Key="BackgroundEffect">背景效果</sys:String>
    <sys:String x:Key="BgGlass">毛玻璃</sys:String>
    <sys:String x:Key="BgMica">Win11 亚克力</sys:String>
    <sys:String x:Key="BgNone">无（纯色）</sys:String>
    <sys:String x:Key="BgHint">毛玻璃实时模糊桌面；Win11 亚克力使用系统材质（需 Windows 10/11）。</sys:String>
    <sys:String x:Key="Help">帮助</sys:String>
    <sys:String x:Key="Tutorial">使用教程</sys:String>
    <sys:String x:Key="Step1">1. 拖入图片到窗口，或按 Ctrl+V 粘贴截图</sys:String>
    <sys:String x:Key="Step2">2. 勾选需要的图片，点击「复制路径」复制到剪贴板</sys:String>
    <sys:String x:Key="Step3">3. 在 AI 终端或任意窗口中 Ctrl+V 粘贴路径即可</sys:String>
    <sys:String x:Key="Step4">4. 点击「粘贴到窗口」可自动将路径粘贴到前台窗口</sys:String>
    <sys:String x:Key="Step5">5. 设置中可切换背景效果、字体、语言和隐私模式</sys:String>
    <sys:String x:Key="FAQ">常见问题</sys:String>
    <sys:String x:Key="Q1">Q: 粘贴到窗口没有反应？</sys:String>
    <sys:String x:Key="A1">A: 点击后在2秒内切换到目标窗口，工具会自动发送 Ctrl+V。</sys:String>
    <sys:String x:Key="Q2">Q: 隐私模式有什么用？</sys:String>
    <sys:String x:Key="A2">A: 开启后所有文件路径会被遮罩为 ********，适用于屏幕共享或演示场景。</sys:String>
    <sys:String x:Key="Q3">Q: 背景效果该选哪个？</sys:String>
    <sys:String x:Key="A3">A: 毛玻璃适合大多数场景；Win11 亚克力使用系统材质更通透；无则为纯色背景。</sys:String>
    <sys:String x:Key="Q4">Q: 字体设置如何生效？</sys:String>
    <sys:String x:Key="A4">A: 在外观设置中点击字体设置，选择字体和字重后点击「应用」即可全局生效。</sys:String>

    <!-- 致谢 -->
    <sys:String x:Key="Credits">致谢</sys:String>
    <sys:String x:Key="CreditMVVM">CommunityToolkit.Mvvm — MVVM 框架</sys:String>
    <sys:String x:Key="CreditDI">Microsoft.Extensions.DependencyInjection — 依赖注入</sys:String>
    <sys:String x:Key="CreditIcons">Game Icon Pack by Nieobie — UI 图标</sys:String>
    <sys:String x:Key="CreditInno">Inno Setup — 安装程序制作工具</sys:String>

    <sys:String x:Key="About">关于</sys:String>
    <sys:String x:Key="AppName">应用名称</sys:String>
    <sys:String x:Key="AppVersion">版本</sys:String>
    <sys:String x:Key="Framework">框架</sys:String>
    <sys:String x:Key="License">协议</sys:String>
    <sys:String x:Key="OpenRepo">打开仓库</sys:String>
    <sys:String x:Key="Website">官网</sys:String>
    <sys:String x:Key="OpenWebsite">打开官网</sys:String>
    <sys:String x:Key="CheckUpdate">检查更新</sys:String>
    <sys:String x:Key="InstallNow">立即安装</sys:String>
    <sys:String x:Key="UpdateBannerText">发现新版本，点击查看详情</sys:String>
    <sys:String x:Key="OpenSourceDev">开源工具开发者</sys:String>

</ResourceDictionary>
