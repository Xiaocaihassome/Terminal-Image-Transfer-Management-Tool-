<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- 主窗口 -->
    <sys:String x:Key="AppTitle">圖片管理助手</sys:String>
    <sys:String x:Key="DropHint">拖入圖片或 Ctrl+V 貼上截圖</sys:String>
    <sys:String x:Key="SelectAll">全選</sys:String>
    <sys:String x:Key="Items">項</sys:String>
    <sys:String x:Key="Selected">已選</sys:String>
    <sys:String x:Key="EmptyState">暫無圖片</sys:String>
    <sys:String x:Key="PasteToWindow">貼上到視窗</sys:String>
    <sys:String x:Key="CopyPath">複製路徑</sys:String>
    <sys:String x:Key="Delete">刪除</sys:String>
    <sys:String x:Key="ClearAll">清空</sys:String>
    <sys:String x:Key="DeleteNoAsk">刪除時不詢問</sys:String>
    <sys:String x:Key="CleanOnExit">退出清空</sys:String>

    <!-- 设置窗口 -->
    <sys:String x:Key="SettingsTitle">設定</sys:String>
    <sys:String x:Key="Personalization">個人化</sys:String>
    <sys:String x:Key="ThemeMode">主題模式</sys:String>
    <sys:String x:Key="Light">淺色</sys:String>
    <sys:String x:Key="Dark">深色</sys:String>
    <sys:String x:Key="FollowSystem">跟隨系統</sys:String>
    <sys:String x:Key="Transparency">透明度</sys:String>
    <sys:String x:Key="Language">語言</sys:String>
    <sys:String x:Key="Storage">儲存</sys:String>
    <sys:String x:Key="TempFolder">臨時資料夾位置</sys:String>
    <sys:String x:Key="SelectFolder">選擇資料夾</sys:String>
    <sys:String x:Key="RestoreDefault">恢復預設</sys:String>
    <sys:String x:Key="OpenFolder">打開資料夾</sys:String>
    <sys:String x:Key="DeleteNoConfirm">刪除時不再詢問</sys:String>
    <sys:String x:Key="AutoCleanOnExit">退出時自動清空臨時檔案</sys:String>
    <sys:String x:Key="ResourcesSection">資源</sys:String>
    <sys:String x:Key="DisableBlur">禁用毛玻璃背景以節省資源</sys:String>
    <sys:String x:Key="Help">幫助</sys:String>
    <sys:String x:Key="Tutorial">使用教程</sys:String>
    <sys:String x:Key="Step1">1. 拖入圖片到視窗，或按 Ctrl+V 貼上截圖</sys:String>
    <sys:String x:Key="Step2">2. 勾選需要的圖片，點擊「複製路徑」</sys:String>
    <sys:String x:Key="Step3">3. 在 AI 終端中 Ctrl+V 貼上路徑即可</sys:String>
    <sys:String x:Key="Step4">4. 點擊「貼上到視窗」可自動貼上到前台視窗</sys:String>
    <sys:String x:Key="FAQ">常見問題</sys:String>
    <sys:String x:Key="Q1">Q: 貼上到視窗沒有反應？</sys:String>
    <sys:String x:Key="A1">A: 點擊後在2秒內切換到目標視窗，工具會自動發送 Ctrl+V。</sys:String>
    <sys:String x:Key="Q2">Q: 圖片儲存在哪裡？</sys:String>
    <sys:String x:Key="A2">A: 預設儲存在系統臨時目錄，可在儲存設定中自訂位置。</sys:String>
    <sys:String x:Key="Q3">Q: 關閉後圖片還在嗎？</sys:String>
    <sys:String x:Key="A3">A: 勾選「退出清空」後關閉視窗會自動刪除臨時檔案。</sys:String>
    <sys:String x:Key="About">關於</sys:String>
    <sys:String x:Key="AppName">應用程式名稱</sys:String>
    <sys:String x:Key="AppVersion">版本</sys:String>
    <sys:String x:Key="Framework">框架</sys:String>
    <sys:String x:Key="License">協議</sys:String>
    <sys:String x:Key="OpenSourceDev">開源工具開發者</sys:String>

</ResourceDictionary>
