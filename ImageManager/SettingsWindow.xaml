<Window x:Class="ImageManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ImageManager.Converters"
        xmlns:svc="clr-namespace:ImageManager.Services"
        Title="{DynamicResource SettingsTitle}"
        Width="420" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="{DynamicResource GlobalFontFamily}"
        FontWeight="{DynamicResource GlobalFontWeight}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
    <Border x:Name="RootBorder" CornerRadius="8"
            Background="{Binding CardBackground, Source={x:Static svc:ThemeManager.Instance}}"
            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="Transparent">
                <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="12" FontWeight="Medium"
                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Click="Close_Click" Width="36" Height="28"
                        HorizontalAlignment="Right"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Border Width="14" Height="14"
                            Background="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}">
                        <Border.OpacityMask>
                            <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/close.png"/>
                        </Border.OpacityMask>
                    </Border>
                </Button>
            </Grid>

            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}"/>

            <!-- 内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="14,10,14,14">
                <StackPanel>

                    <!-- ===== 外观 ===== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="16" Height="16" Margin="0,0,6,0"
                                Background="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/fill.png"/>
                            </Border.OpacityMask>
                        </Border>
                        <TextBlock Text="{DynamicResource Appearance}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="AppearanceCard" Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ThemeMode}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <WrapPanel>
                                <RadioButton Content="{DynamicResource Light}"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=Light}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="Light"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="{DynamicResource Dark}"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=Dark}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="Dark"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="{DynamicResource FollowSystem}"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=System}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="System"
                                             Style="{DynamicResource ThemeRadioStyle}"/>
                            </WrapPanel>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,10"/>

                              <TextBlock Text="{DynamicResource Transparency}" FontSize="11" Margin="0,10,0,4"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="30%"
                                           FontSize="9" VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <Slider Grid.Column="1" Minimum="0.3" Maximum="1.0"
                                        Value="{Binding Transparency, Mode=TwoWay}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Width="32" TextAlignment="Right"
                                           FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           Text="{Binding Transparency, StringFormat={}{0:0%}}"/>
                                <TextBlock Grid.Column="3" Text="100%"
                                           FontSize="9" VerticalAlignment="Center" Margin="4,0,0,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>

                            <TextBlock Text="{DynamicResource BackgroundEffect}" FontSize="11" Margin="0,0,0,6"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            <WrapPanel>
                                <RadioButton Content="{DynamicResource BgGlass}"
                                             IsChecked="{Binding BackgroundMode, Converter={StaticResource ThemeToBool}, ConverterParameter=Glass}"
                                             Command="{Binding SetBackgroundModeCommand}" CommandParameter="Glass"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="{DynamicResource BgMica}"
                                             IsChecked="{Binding BackgroundMode, Converter={StaticResource ThemeToBool}, ConverterParameter=Mica}"
                                             Command="{Binding SetBackgroundModeCommand}" CommandParameter="Mica"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="{DynamicResource BgNone}"
                                             IsChecked="{Binding BackgroundMode, Converter={StaticResource ThemeToBool}, ConverterParameter=None}"
                                             Command="{Binding SetBackgroundModeCommand}" CommandParameter="None"
                                             Style="{DynamicResource ThemeRadioStyle}"/>
                            </WrapPanel>
                            <TextBlock Text="{DynamicResource BgHint}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding BackdropWarning}" FontSize="10"
                                       Foreground="#E81123"
                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                       Visibility="{Binding HasBackdropWarning, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 字体设置独立卡片 -->
                    <Border x:Name="FontCard" CornerRadius="8" Padding="12" Margin="0,8,0,0"
                            Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1.5">
                        <Grid Cursor="Hand" MouseLeftButtonDown="OpenFontSettings_Click" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0"
                                    Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}">
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/font3.png"/>
                                </Border.OpacityMask>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource FontSelect}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Text="{DynamicResource FontSettingDesc}" FontSize="10"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="&#x276F;" FontSize="14"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,12"/>

                    <!-- ===== 语言 ===== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="16" Height="16" Margin="0,0,6,0"
                                Background="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/globe.png"/>
                            </Border.OpacityMask>
                        </Border>
                        <TextBlock Text="{DynamicResource Language}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="LanguageCard" Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <WrapPanel>
                            <RadioButton Content="简体中文"
                                         IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=zh-CN}"
                                         Command="{Binding SetLanguageCommand}" CommandParameter="zh-CN"
                                         Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                            <RadioButton Content="繁體中文"
                                         IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=zh-TW}"
                                         Command="{Binding SetLanguageCommand}" CommandParameter="zh-TW"
                                         Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                            <RadioButton Content="English"
                                         IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=en-US}"
                                         Command="{Binding SetLanguageCommand}" CommandParameter="en-US"
                                         Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                            <RadioButton Content="한국어"
                                         IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=ko-KR}"
                                         Command="{Binding SetLanguageCommand}" CommandParameter="ko-KR"
                                         Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                            <RadioButton Content="日本語"
                                         IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=ja-JP}"
                                         Command="{Binding SetLanguageCommand}" CommandParameter="ja-JP"
                                         Style="{DynamicResource ThemeRadioStyle}"/>
                        </WrapPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,12"/>

                    <!-- ===== 存储 ===== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="16" Height="16" Margin="0,0,6,0"
                                Background="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/folder2.png"/>
                            </Border.OpacityMask>
                        </Border>
                        <TextBlock Text="{DynamicResource Storage}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="StorageCard" Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TempFolder}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,4"/>

                            <Border Background="{Binding ButtonBg, Source={x:Static svc:ThemeManager.Instance}}"
                                    CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                                <TextBlock Text="{Binding DisplayTempPath}"
                                           FontSize="10" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="{DynamicResource SelectFolder}" Command="{Binding BrowseTempPathCommand}"
                                        Padding="8,5" FontSize="10" Margin="0,0,4,0"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                                <Button Content="{DynamicResource RestoreDefault}" Command="{Binding RestoreDefaultPathCommand}"
                                        Padding="8,5" FontSize="10" Margin="0,0,4,0"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                                <Button Content="{DynamicResource OpenFolder}" Command="{Binding OpenCurrentFolderCommand}"
                                        Padding="8,5" FontSize="10"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,12"/>

                    <!-- ===== 隐私 ===== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="16" Height="16" Margin="0,0,6,0"
                                Background="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/hidden.png"/>
                            </Border.OpacityMask>
                        </Border>
                        <TextBlock Text="{DynamicResource PrivacyMode}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="BehaviorCard" Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                    Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/hidden.png"/>
                                </Border.OpacityMask>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource PrivacyMode}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Text="{DynamicResource PrivacyModeDesc}" FontSize="9"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="PrivacyCheckBox" Grid.Column="2" IsChecked="{Binding PrivacyMode}"
                                      VerticalAlignment="Center" Margin="8,0,0,0"
                                      Checked="PrivacyCheckBox_Changed" Unchecked="PrivacyCheckBox_Changed"/>
                        </Grid>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,12"/>

                    <!-- ===== 粘贴设置 ===== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="16" Height="16" Margin="0,0,6,0"
                                Background="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/copy.png"/>
                            </Border.OpacityMask>
                        </Border>
                        <TextBlock Text="粘贴设置" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="PasteCard" Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                        Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border.OpacityMask>
                                        <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/copy.png"/>
                                    </Border.OpacityMask>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource AutoDetectClipboard}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                    <TextBlock Text="{DynamicResource AutoDetectClipboardDesc}" FontSize="9"
                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                               TextWrapping="Wrap" Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoDetectClipboardCheckBox" Grid.Column="2" IsChecked="{Binding AutoDetectClipboard}"
                                          VerticalAlignment="Center" Margin="8,0,0,0"
                                          Checked="AutoDetectClipboardCheckBox_Changed" Unchecked="AutoDetectClipboardCheckBox_Changed"/>
                            </Grid>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0"/>

                            <Grid Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                        Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border.OpacityMask>
                                        <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/arrow_up.png"/>
                                    </Border.OpacityMask>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource AutoReturnToTarget}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                    <TextBlock Text="{DynamicResource AutoReturnToTargetDesc}" FontSize="9"
                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                               TextWrapping="Wrap" Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="AutoReturnToTargetCheckBox" Grid.Column="2" IsChecked="{Binding AutoReturnToTarget}"
                                          VerticalAlignment="Center" Margin="8,0,0,0"
                                          Checked="AutoReturnToTargetCheckBox_Changed" Unchecked="AutoReturnToTargetCheckBox_Changed"/>
                            </Grid>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                        Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border.OpacityMask>
                                        <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/trash.png"/>
                                    </Border.OpacityMask>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource DeleteAfterPaste}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                    <TextBlock Text="{DynamicResource DeleteAfterPasteDesc}" FontSize="9"
                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                               TextWrapping="Wrap" Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" IsChecked="{Binding DeleteAfterPaste}"
                                          VerticalAlignment="Center" Margin="8,0,0,0"
                                          Checked="DeleteAfterPasteCheckBox_Changed" Unchecked="DeleteAfterPasteCheckBox_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,12"/>

                    <!-- ===== 通用设置 ===== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="16" Height="16" Margin="0,0,6,0"
                                Background="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/tune.png"/>
                            </Border.OpacityMask>
                        </Border>
                        <TextBlock Text="通用设置" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="GeneralCard" Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                        Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border.OpacityMask>
                                        <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/lock.png"/>
                                    </Border.OpacityMask>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource AlwaysOnTop}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                    <TextBlock Text="{DynamicResource AlwaysOnTopDesc}" FontSize="9"
                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                               TextWrapping="Wrap" Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="AlwaysOnTopCheckBox" Grid.Column="2" IsChecked="{Binding AlwaysOnTop}"
                                          VerticalAlignment="Center" Margin="8,0,0,0"
                                          Checked="AlwaysOnTopCheckBox_Changed" Unchecked="AlwaysOnTopCheckBox_Changed"/>
                            </Grid>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0"/>

                            <Grid Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                        Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border.OpacityMask>
                                        <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/power.png"/>
                                    </Border.OpacityMask>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource AutoStart}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                    <TextBlock Text="{DynamicResource AutoStartDesc}" FontSize="9"
                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                               TextWrapping="Wrap" Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" IsChecked="{Binding AutoStart}"
                                          VerticalAlignment="Center" Margin="8,0,0,0"
                                          Checked="AutoStartCheckBox_Changed" Unchecked="AutoStartCheckBox_Changed"/>
                            </Grid>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                        Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border.OpacityMask>
                                        <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/reload.png"/>
                                    </Border.OpacityMask>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource SkipUpdateReminder}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                    <TextBlock Text="{DynamicResource SkipUpdateReminderDesc}" FontSize="9"
                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                               TextWrapping="Wrap" Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" IsChecked="{Binding SkipUpdateReminder}"
                                          VerticalAlignment="Center" Margin="8,0,0,0"
                                          Checked="SkipUpdateReminder_Changed" Unchecked="SkipUpdateReminder_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

<!-- ===== 关于 ===== -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="16" Height="16" Margin="0,0,6,0"
                                Background="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/info.png"/>
                            </Border.OpacityMask>
                        </Border>
                        <TextBlock Text="{DynamicResource About}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="AboutCard" Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="40" Height="40" CornerRadius="20" ClipToBounds="True"
                                        Margin="0,0,10,0">
                                    <Image Source="pack://application:,,,/Resources/avatar.png"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="小蔡有点料" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource AppName}" FontSize="11"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="{DynamicResource AppTitle}" FontSize="11"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource AppVersion}" FontSize="11"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="11"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Framework}" FontSize="11"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text=".NET 8 + WPF" FontSize="11"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource License}" FontSize="11"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="MIT License" FontSize="11"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="GitHub" FontSize="11"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="{DynamicResource OpenRepo}" FontSize="11"
                                           Foreground="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                           Cursor="Hand" MouseLeftButtonDown="OpenRepo_Click"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Website}" FontSize="11"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="{DynamicResource OpenWebsite}" FontSize="11"
                                           Foreground="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                           Cursor="Hand" MouseLeftButtonDown="OpenWebsite_Click"/>
                            </Grid>

                            <!-- 检查更新 -->

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{DynamicResource CheckUpdate}">
                                    <Border Width="16" Height="16" Margin="0,0,6,0"
                                            Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}">
                                        <Border.OpacityMask>
                                            <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/reload.png"/>
                                        </Border.OpacityMask>
                                    </Border>
                                    <TextBlock Text="{DynamicResource CheckUpdate}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="CheckUpdateButton" Command="{Binding CheckUpdateCommand}"
                                            Padding="14,7" FontSize="11" Cursor="Hand" MinWidth="100"
                                            Background="{Binding Accent, Source={x:Static svc:ThemeManager.Instance}}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            ToolTip="{DynamicResource CheckUpdateTip}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="6"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock FontSize="11" Foreground="White">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding UpdateButtonText}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UpdateButtonText}" Value="">
                                                                <Setter Property="Text" Value="{DynamicResource CheckUpdate}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Ellipse Width="8" Height="8" Fill="#FFD700" Margin="6,0,0,0"
                                                     VerticalAlignment="Center"
                                                     Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding DownloadUpdateCommand}"
                                            Padding="14,7" FontSize="11" Cursor="Hand"
                                            Background="#2EA043" Foreground="White"
                                            BorderThickness="0" Margin="6,0,0,0"
                                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="6"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="{Binding DownloadButtonText}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                            <!-- 查看日志 -->
                            <Button Click="OpenLogs_Click" Cursor="Hand"
                                    Padding="10,6" FontSize="11"
                                    Background="{Binding ButtonBg, Source={x:Static svc:ThemeManager.Instance}}"
                                    Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                    BorderThickness="0" HorizontalAlignment="Left">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="6"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{Binding ButtonHover, Source={x:Static svc:ThemeManager.Instance}}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="12" Height="12" Margin="0,0,4,0"
                                            Background="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}">
                                        <Border.OpacityMask>
                                            <ImageBrush ImageSource="pack://application:,,,/Resources/Icons/folder.png"/>
                                        </Border.OpacityMask>
                                    </Border>
                                    <TextBlock Text="{DynamicResource ViewLogs}"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="{DynamicResource Tutorial}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource Step1}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,3"/>
                            <TextBlock Text="{DynamicResource Step2}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,3"/>
                            <TextBlock Text="{DynamicResource Step3}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,3"/>
                            <TextBlock Text="{DynamicResource Step4}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,3"/>
                            <TextBlock Text="{DynamicResource Step5}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                            <TextBlock Text="{DynamicResource FAQ}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource Q1}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="{DynamicResource A1}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource Q2}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="{DynamicResource A2}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource Q3}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="{DynamicResource A3}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource Q4}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="{DynamicResource A4}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,12"/>

                            <TextBlock Text="{DynamicResource Credits}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource CreditMVVM}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,3"/>
                            <TextBlock Text="{DynamicResource CreditDI}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,3"/>
                            <TextBlock Text="{DynamicResource CreditIcons}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,3"/>
                            <TextBlock Text="{DynamicResource CreditInno}" FontSize="10"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,12"/>

                            <TextBlock Text="{DynamicResource Disclaimer}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource DisclaimerText}" FontSize="9"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                       TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>

    <!-- 缩放拖拽手柄 -->
    <Border x:Name="ResizeN"  Height="4" VerticalAlignment="Top"    HorizontalAlignment="Stretch" Cursor="SizeNS" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeS"  Height="4" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Cursor="SizeNS" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeW"  Width="4"  VerticalAlignment="Stretch" HorizontalAlignment="Left"   Cursor="SizeWE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeE"  Width="4"  VerticalAlignment="Stretch" HorizontalAlignment="Right"  Cursor="SizeWE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeNW" Width="8" Height="8" VerticalAlignment="Top"    HorizontalAlignment="Left"   Cursor="SizeNWSE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeNE" Width="8" Height="8" VerticalAlignment="Top"    HorizontalAlignment="Right"  Cursor="SizeNESW" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeSW" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Left"   Cursor="SizeNESW" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeSE" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Right"  Cursor="SizeNWSE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    </Grid>
</Window>
