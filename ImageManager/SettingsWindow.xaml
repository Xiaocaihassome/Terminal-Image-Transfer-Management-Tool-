<Window x:Class="ImageManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:ImageManager.Services"
        Title="{DynamicResource SettingsTitle}"
        Icon="pack://application:,,,/Resources/app.png"
        Width="420" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid>
    <Border x:Name="RootBorder" CornerRadius="12" Background="{Binding CardBackground, Source={x:Static svc:ThemeManager.Instance}}"
            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="Transparent">
                <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="13" FontWeight="Medium"
                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button Click="Close_Click" Width="36" Height="28"
                        HorizontalAlignment="Right"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}">
                    <TextBlock Text="&#x2715;" FontSize="11" Margin="0,-1,0,0"/>
                </Button>
            </Grid>

            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}"/>

            <!-- 内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="16,12,16,16">
                <StackPanel>

                    <!-- ===== 个性化 ===== -->
                    <TextBlock Text="{DynamicResource Personalization}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ThemeMode}" FontSize="12"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <RadioButton Content="{DynamicResource Light}"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=Light}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="Light"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="{DynamicResource Dark}"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=Dark}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="Dark"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="{DynamicResource FollowSystem}"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=System}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="System"
                                             Style="{DynamicResource ThemeRadioStyle}"/>
                            </WrapPanel>

                            <TextBlock Text="{DynamicResource Transparency}" FontSize="12" Margin="0,12,0,6"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="30%"
                                           FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <Slider Grid.Column="1" Minimum="0.3" Maximum="1.0"
                                        Value="{Binding Transparency, Mode=TwoWay}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Width="36" TextAlignment="Right"
                                           FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           Text="{Binding Transparency, StringFormat={}{0:0%}}"/>
                                <TextBlock Grid.Column="3" Text="100%"
                                           FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,14"/>

                    <!-- ===== 语言 ===== -->
                    <TextBlock Text="{DynamicResource Language}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <WrapPanel>
                                <RadioButton Content="简体中文"
                                             IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=zh-CN}"
                                             Command="{Binding SetLanguageCommand}" CommandParameter="zh-CN"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="繁體中文"
                                             IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=zh-TW}"
                                             Command="{Binding SetLanguageCommand}" CommandParameter="zh-TW"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="English"
                                             IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=en-US}"
                                             Command="{Binding SetLanguageCommand}" CommandParameter="en-US"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="한국어"
                                             IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=ko-KR}"
                                             Command="{Binding SetLanguageCommand}" CommandParameter="ko-KR"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="日本語"
                                             IsChecked="{Binding CurrentLanguage, Converter={StaticResource ThemeToBool}, ConverterParameter=ja-JP}"
                                             Command="{Binding SetLanguageCommand}" CommandParameter="ja-JP"
                                             Style="{DynamicResource ThemeRadioStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,14"/>

                    <!-- ===== 存储 ===== -->
                    <TextBlock Text="{DynamicResource Storage}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TempFolder}" FontSize="12"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>

                            <Border Background="{Binding ButtonBg, Source={x:Static svc:ThemeManager.Instance}}"
                                    CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                                <TextBlock Text="{Binding DisplayTempPath}"
                                           FontSize="11" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="{DynamicResource SelectFolder}" Command="{Binding BrowseTempPathCommand}"
                                        Padding="10,6" FontSize="11" Margin="0,0,6,0"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                                <Button Content="{DynamicResource RestoreDefault}" Command="{Binding RestoreDefaultPathCommand}"
                                        Padding="10,6" FontSize="11" Margin="0,0,6,0"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                                <Button Content="{DynamicResource OpenFolder}" Command="{Binding OpenCurrentFolderCommand}"
                                        Padding="10,6" FontSize="11"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                            </StackPanel>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                            <CheckBox Content="{DynamicResource DeleteNoConfirm}"
                                      IsChecked="{Binding DeleteWithoutConfirm}"
                                      FontSize="12" Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <CheckBox Content="{DynamicResource AutoCleanOnExit}"
                                      IsChecked="{Binding AutoCleanOnExit}"
                                      FontSize="12" Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,14"/>

                    <!-- ===== 资源 ===== -->
                    <TextBlock Text="{DynamicResource ResourcesSection}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource DisableBlur}"
                                      IsChecked="{Binding DisableBlur}"
                                      FontSize="12" Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,14"/>

                    <!-- ===== 帮助 ===== -->
                    <TextBlock Text="{DynamicResource Help}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Tutorial}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Step1}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource Step2}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource Step3}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource Step4}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,12"/>

                            <TextBlock Text="{DynamicResource FAQ}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Q1}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="{DynamicResource A1}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Q2}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="{DynamicResource A2}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Q3}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="{DynamicResource A3}" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,14"/>

                    <!-- ===== 关于 ===== -->
                    <TextBlock Text="{DynamicResource About}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="48" Height="48" CornerRadius="24" ClipToBounds="True"
                                        Margin="0,0,12,0">
                                    <Image Source="pack://application:,,,/Resources/avatar.png"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="小蔡有点料" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                    <TextBlock Text="{DynamicResource OpenSourceDev}" FontSize="11"
                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource AppName}" FontSize="12"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="图片管理助手" FontSize="12"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource AppVersion}" FontSize="12"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="12"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Framework}" FontSize="12"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text=".NET 8 + WPF" FontSize="12"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource License}" FontSize="12"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="MIT License" FontSize="12"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>

    <!-- 缩放拖拽手柄 -->
    <Border x:Name="ResizeN"  Height="5" VerticalAlignment="Top"    HorizontalAlignment="Stretch" Cursor="SizeNS" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeS"  Height="5" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Cursor="SizeNS" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeW"  Width="5"  VerticalAlignment="Stretch" HorizontalAlignment="Left"   Cursor="SizeWE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeE"  Width="5"  VerticalAlignment="Stretch" HorizontalAlignment="Right"  Cursor="SizeWE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeNW" Width="10" Height="10" VerticalAlignment="Top"    HorizontalAlignment="Left"   Cursor="SizeNWSE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeNE" Width="10" Height="10" VerticalAlignment="Top"    HorizontalAlignment="Right"  Cursor="SizeNESW" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeSW" Width="10" Height="10" VerticalAlignment="Bottom" HorizontalAlignment="Left"   Cursor="SizeNESW" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    <Border x:Name="ResizeSE" Width="10" Height="10" VerticalAlignment="Bottom" HorizontalAlignment="Right"  Cursor="SizeNWSE" Background="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
    </Grid>
</Window>
