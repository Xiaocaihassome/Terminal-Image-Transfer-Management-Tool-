<Window x:Class="ImageManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:ImageManager.Services"
        Title="设置"
        Width="500" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei, Segoe UI"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border CornerRadius="12" Background="{Binding CardBackground, Source={x:Static svc:ThemeManager.Instance}}"
            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="Transparent">
                <TextBlock Text="设置" FontSize="13" FontWeight="Medium"
                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button Click="Close_Click" Width="36" Height="28"
                        HorizontalAlignment="Right"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}">
                    <TextBlock Text="&#x2715;" FontSize="11" Margin="0,-1,0,0"/>
                </Button>
            </Grid>

            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                    Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}"/>

            <!-- 内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="16,12,16,16">
                <StackPanel>

                    <!-- ===== 个性化 ===== -->
                    <TextBlock Text="&#x2699;  个性化" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="主题模式" FontSize="12"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <RadioButton Content="浅色"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=Light}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="Light"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="深色"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=Dark}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="Dark"
                                             Style="{DynamicResource ThemeRadioStyle}" Margin="0,0,6,0"/>
                                <RadioButton Content="跟随系统"
                                             IsChecked="{Binding CurrentTheme, Converter={StaticResource ThemeToBool}, ConverterParameter=System}"
                                             Command="{Binding SetThemeCommand}" CommandParameter="System"
                                             Style="{DynamicResource ThemeRadioStyle}"/>
                            </WrapPanel>

                            <TextBlock Text="透明度" FontSize="12" Margin="0,12,0,6"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="30%"
                                           FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <Slider Grid.Column="1" Minimum="0.3" Maximum="1.0"
                                        Value="{Binding Transparency, Mode=TwoWay}"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Width="36" TextAlignment="Right"
                                           FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           Text="{Binding Transparency, StringFormat={}{0:0%}}"/>
                                <TextBlock Grid.Column="3" Text="100%"
                                           FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,14"/>

                    <!-- ===== 存储 ===== -->
                    <TextBlock Text="存储" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="临时文件夹位置" FontSize="12"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>

                            <Border Background="{Binding ButtonBg, Source={x:Static svc:ThemeManager.Instance}}"
                                    CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                                <TextBlock Text="{Binding DisplayTempPath}"
                                           FontSize="11" Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="选择文件夹" Command="{Binding BrowseTempPathCommand}"
                                        Padding="10,6" FontSize="11" Margin="0,0,6,0"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                                <Button Content="恢复默认" Command="{Binding RestoreDefaultPathCommand}"
                                        Padding="10,6" FontSize="11" Margin="0,0,6,0"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                                <Button Content="打开文件夹" Command="{Binding OpenCurrentFolderCommand}"
                                        Padding="10,6" FontSize="11"
                                        Style="{DynamicResource SettingsButtonStyle}"/>
                            </StackPanel>

                            <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                            <CheckBox Content="删除时不再询问"
                                      IsChecked="{Binding DeleteWithoutConfirm}"
                                      FontSize="12" Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,6"/>
                            <CheckBox Content="退出时自动清空临时文件"
                                      IsChecked="{Binding AutoCleanOnExit}"
                                      FontSize="12" Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,14"/>

                    <!-- ===== 帮助 ===== -->
                    <TextBlock Text="?  帮助" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="使用教程" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <TextBlock Text="1. 拖入图片到窗口，或按 Ctrl+V 粘贴截图" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,4"/>
                            <TextBlock Text="2. 勾选需要的图片，点击「复制路径」" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,4"/>
                            <TextBlock Text="3. 在 AI 终端中 Ctrl+V 粘贴路径即可" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,4"/>
                            <TextBlock Text="4. 点击「粘贴到窗口」可自动粘贴到前台窗口" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,12"/>

                            <TextBlock Text="常见问题" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <TextBlock Text="Q: 粘贴到窗口没有反应？" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="A: 点击后在2秒内切换到目标窗口，工具会自动发送 Ctrl+V。" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <TextBlock Text="Q: 图片保存在哪里？" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="A: 默认保存在系统临时目录，可在存储设置中自定义位置。" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,8"/>
                            <TextBlock Text="Q: 关闭后图片还在吗？" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,2"/>
                            <TextBlock Text="A: 勾选「退出清空」后关闭窗口会自动删除临时文件。" FontSize="11"
                                       Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{Binding Separator, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,14"/>

                    <!-- ===== 关于 ===== -->
                    <TextBlock Text="i  关于" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}" Margin="0,0,0,10"/>

                    <Border Background="{Binding ListBackground, Source={x:Static svc:ThemeManager.Instance}}"
                            CornerRadius="10" Padding="14"
                            BorderBrush="{Binding CardBorder, Source={x:Static svc:ThemeManager.Instance}}" BorderThickness="1">
                        <StackPanel>
                            <!-- 作者信息 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="48" Height="48" CornerRadius="24" ClipToBounds="True"
                                        Margin="0,0,12,0">
                                    <Image Source="pack://application:,,,/Resources/avatar.png"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="小蔡有点料" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                    <TextBlock Text="开源工具开发者" FontSize="11"
                                               Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="应用名称" FontSize="12"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="图片管理助手" FontSize="12"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="版本" FontSize="12"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="12"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="框架" FontSize="12"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text=".NET 8 + WPF" FontSize="12"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="协议" FontSize="12"
                                           Foreground="{Binding TextSecondary, Source={x:Static svc:ThemeManager.Instance}}"/>
                                <TextBlock Grid.Column="1" Text="MIT License" FontSize="12"
                                           Foreground="{Binding TextPrimary, Source={x:Static svc:ThemeManager.Instance}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
