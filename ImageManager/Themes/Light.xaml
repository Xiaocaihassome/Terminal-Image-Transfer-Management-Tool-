<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="CardBackground" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ListBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorder" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#777777"/>
    <SolidColorBrush x:Key="Accent" Color="#0078D4"/>
    <SolidColorBrush x:Key="ButtonBg" Color="#EBEBEB"/>
    <SolidColorBrush x:Key="ButtonHover" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="ButtonPressed" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="DangerBg" Color="#FDE7E7"/>
    <SolidColorBrush x:Key="DangerFg" Color="#E81123"/>
    <SolidColorBrush x:Key="DangerHover" Color="#F5D0D0"/>
